ENVIRONMENT=local
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_S=30
JOB_EXECUTION_TIMEOUT_S=300

# PostgreSQL (managed by backend-python)
DATABASE_URL=postgresql+asyncpg://postgres:postgrespw@localhost:5432/backend_python
DATABASE_POOL_MAX=20
DATABASE_COMMAND_TIMEOUT_S=10

# Redis (managed by backend-python)
REDIS_HOST=redis://:@localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMAND_TIMEOUT_S=5

# RabbitMQ (managed by backend-python; disabled by default)
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_PUBLISH_TIMEOUT_S=5

# Jobs
HEALTH_CHECK_CRON=*/1 * * * *
HEALTH_CHECK_ENABLED=true
