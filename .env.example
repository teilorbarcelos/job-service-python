# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespw
POSTGRES_DB=backend_python
DATABASE_URL=postgresql+asyncpg://postgres:postgrespw@localhost:5432/backend_python

# Security
JWT_SECRET=local-development-secret-key
JWT_ISSUER=backend-python
JWT_AUDIENCE=backend-python-api
JWT_ACCESS_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7
PASSWORD_BCRYPT_COST=12

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# App
ENVIRONMENT=local
PORT=8888
FIRST_USER=admin@email.com
FIRST_PASSWORD=admin123

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# RabbitMQ
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_USER=guest
RABBIT_PASSWORD=guest

# Storage
STORAGE_DISK=local
STORAGE_PATH=./storage/app
STORAGE_URL=http://localhost:8888/storage

# PDF Service
PDF_SERVICE_URL=http://localhost:8889
AUTH_MODE=local  # local = monolithic auth, remote = delegate to auth-service-python
