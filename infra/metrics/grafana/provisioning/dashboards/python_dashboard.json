    },
    {
      "title": "Queries no Banco (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(db_queries_total[30s]) * 60",
          "legendFormat": "Consultas Banco",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noDataValue": "0"
        }
      }
    }

