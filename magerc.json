{
  "scripts": [
    {
      "name": "🛠️ Install Dependencies",
      "command": "make setup"
    },
    {
      "name": "🚀 Start Job Runner (dev)",
      "command": "make dev"
    },
    {
      "name": "🐳 Infrastructure: Start All (Postgres, Redis, RabbitMQ)",
      "command": "make infra-up"
    },
    {
      "name": "🐳 Infrastructure: Stop Services",
      "command": "make infra-down"
    },
    {
      "name": "🧪 Run Tests",
      "command": "make test"
    },
    {
      "name": "📊 Code Coverage Report",
      "command": "make coverage"
    },
    {
      "name": "🧹 Lint with ruff",
      "command": "make lint"
    },
    {
      "name": "🎨 Format with ruff",
      "command": "make format"
    },
    {
      "name": "🔍 Typecheck with mypy",
      "command": "make typecheck"
    },
    {
      "name": "✅ Check (lint + typecheck + test)",
      "command": "make check"
    },
    {
      "name": "📡 SonarQube Scanner",
      "command": "make sonar"
    },
    {
      "name": "🏗️ Generate New Job (make generate-job name=Cleanup)",
      "command": "make generate-job"
    }
  ],
  "replacements": [
    {
      "path": "requirements.txt",
      "pattern": "backend-python"
    },
    {
      "path": "pyproject.toml",
      "pattern": "backend-python"
    }
  ]
}
