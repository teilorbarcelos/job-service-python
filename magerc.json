{
  "scripts": [
    {
      "name": "Install Dependencies",
      "command": "make setup"
    },
    {
      "name": "Start Infrastructure",
      "command": "make infra-up"
    },
    {
      "name": "Stop Infrastructure",
      "command": "make infra-down"
    },
    {
      "name": "Start Development Server",
      "command": "make dev"
    },
    {
      "name": "Run Tests",
      "command": "make test"
    },
    {
      "name": "Run Coverage",
      "command": "make coverage"
    },
    {
      "name": "Start Metrics (Grafana & Prometheus)",
      "command": "make metrics-up"
    },
    {
      "name": "Stop Metrics",
      "command": "make metrics-stop"
    },
    {
      "name": "Down Metrics (Remove Containers)",
      "command": "make metrics-down"
    },
    {
      "name": "Generate Module",
      "command": "make generate"
    },
    {
      "name": "Install Storage: AWS S3",
      "command": "make storage-driver name=s3"
    },
    {
      "name": "Install Storage: Google Cloud (GCS)",
      "command": "make storage-driver name=gcs"
    },
    {
      "name": "Install Storage: Azure Blob",
      "command": "make storage-driver name=azure"
    }
  ],
  "replacements": [
    {
      "path": "requirements.txt",
      "pattern": "backend-python"
    }
  ]
}
